{
  "name": "smart-education",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npx ts-node build.ts",
    "start": "node dist/bin/www.js",
    "dev:start": "nodemon --exec ts-node src/bin/www.ts",
    "server:start": "SET DEBUG=smart-education:* & npm run dev:start",
    "watch": "tsc -w",
    "lint": "eslint src/**/*.{ts,tsx,json,pug}",
    "lint:fix": "eslint --fix src/**/*.{ts,tsx,json,pug}",
    "format": "prettier --write src/**/*.{ts,tsx,json,pug}",
    "typeorm": "npx typeorm-ts-node-commonjs",
    "migrate:generate": "npm run typeorm -- migration:generate -d ./src/config/data-source.ts",
    "migrate:run": "npm run typeorm -- migration:run -d ./src/config/data-source.ts",
    "migrate:revert": "npm run typeorm -- migration:revert -d ./src/config/data-source.ts",
    "migrate:show": "npm run typeorm -- migration:show -d ./src/config/data-source.ts",
    "tailwind:css": "postcss src/public/stylesheets/tailwind.css -o src/public/stylesheets/global.css -w",
    "seed": "npx ts-node src/seed.ts",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:cov": "cross-env NODE_ENV=test jest --coverage"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.4.0",
    "cookie-parser": "~1.4.6",
    "crypto": "^1.0.1",
    "debug": "~4.3.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "~4.19.2",
    "express-async-handler": "^1.2.0",
    "express-flash": "^0.0.2",
    "express-mysql-session": "^3.0.3",
    "express-session": "^1.18.0",
    "fs-extra": "^11.2.0",
    "http-errors": "~2.0.0",
    "i18next": "^23.12.2",
    "i18next-fs-backend": "^2.3.2",
    "i18next-http-middleware": "^3.6.0",
    "jet-logger": "^1.3.1",
    "morgan": "~1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.10.3",
    "nodemailer": "^6.9.14",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "peer": "^1.0.2",
    "pug": "^3.0.3",
    "react": "^18.3.1",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@eslint/compat": "^1.1.1",
    "@eslint/js": "^9.7.0",
    "@prettier/plugin-pug": "^3.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/debug": "^4.1.12",
    "@types/express-flash": "^0.0.5",
    "@types/express-mysql-session": "^3.0.6",
    "@types/express-session": "^1.18.0",
    "@types/fs-extra": "^11.0.4",
    "@types/http-errors": "^2.0.4",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.12",
    "@types/nodemailer": "^6.4.15",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pug": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-pug": "^1.2.5",
    "eslint-plugin-react": "^7.35.0",
    "globals": "^15.8.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.40",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.7",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^7.17.0"
  },
  "description": "Project with Node.js and Express framework for a major assignment in the Sofware Development Laboratory.",
  "main": "src/bin/www.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PhamMinhVuong21020425/smart-education"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/PhamMinhVuong21020425/smart-education/issues"
  },
  "homepage": "https://github.com/PhamMinhVuong21020425/smart-education#readme"
}
